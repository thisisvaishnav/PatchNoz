# Copy this file to .env and fill in the values you have.
# PatchNoz runs end-to-end with none of these set - it just falls back to
# dry-run actions and "source: error" evidence items where a real
# integration would otherwise be used.

# --- SigNoz ---
SIGNOZ_BASE_URL=http://localhost:8080
SIGNOZ_MCP_URL=http://localhost:8000/mcp

# Preferred auth for the SigNoz MCP adapter:
SIGNOZ_API_KEY=

# Fallback auth (used only if SIGNOZ_API_KEY is empty):
SIGNOZ_EMAIL=
SIGNOZ_PASSWORD=
SIGNOZ_ORG_ID=

# --- Self-telemetry (PatchNoz's own OTel spans) ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# --- Actions ---
# Slack Incoming Webhook URL; leave empty to dry-run the Slack action.
SLACK_WEBHOOK_URL=

# GitHub issue creation; leave any of these empty to dry-run the GitHub action.
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=
