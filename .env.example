# PatchNoz environment variables
# Copy this file to .env and fill in your values.
# Variables already set in your shell take priority over .env.

# --- LLM (required for investigation) ---
# Free API key at https://aistudio.google.com (no credit card needed)
GEMINI_API_KEY=your_gemini_api_key_here
# Model to use. gemini-2.5-flash is the default (free tier, fast, good tool-calling).
# GEMINI_MODEL=gemini-2.5-flash

# Max SigNoz tool calls per investigation (default 12, raise if complex incidents need more)
# PATCHNOZ_MAX_TOOL_CALLS=12

# --- SigNoz ---
# Base URL of the SigNoz UI (used for deep links in Slack/GitHub)
SIGNOZ_BASE_URL=http://localhost:8080

# URL of the SigNoz prebuilt MCP server
SIGNOZ_MCP_URL=http://localhost:8000/mcp

# SigNoz API key (preferred auth method)
SIGNOZ_API_KEY=

# Fallback auth if no API key: email/password login
SIGNOZ_EMAIL=
SIGNOZ_PASSWORD=
SIGNOZ_ORG_ID=

# --- OpenTelemetry (PatchNoz's own self-tracing) ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# --- Slack (optional -- enables real posts; dry-runs if unset) ---
SLACK_WEBHOOK_URL=

# --- GitHub (optional -- enables real issues; dry-runs if unset) ---
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=

# --- Scanner ---
# Interval between scan cycles in seconds (default 900 = 15 minutes)
# PATCHNOZ_SCAN_INTERVAL_SECS=900
